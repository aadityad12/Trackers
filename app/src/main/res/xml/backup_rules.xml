<?xml version="1.0" encoding="utf-8"?><!--
   Auto Backup rules for API 26-30. Devices on API 31+ use data_extraction_rules.xml
   instead and ignore this file entirely, so the exclusions below are duplicated there
   — keep the two in sync.
   See https://developer.android.com/guide/topics/data/autobackup

   Rationale for each exclusion is documented in data_extraction_rules.xml (Issue #62).
-->
<full-backup-content>
    <exclude domain="database" path="budget_database" />
    <exclude domain="database" path="budget_database-wal" />
    <exclude domain="database" path="budget_database-shm" />
    <exclude domain="sharedpref" path="device_identity.xml" />
</full-backup-content>
